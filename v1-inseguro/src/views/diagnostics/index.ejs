<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Diagnostics | IT Helpdesk</title>
  </head>
  <body>
    <main>
      <p><a href="/dashboard">Back to dashboard</a></p>
      <h1>Network diagnostics</h1>
      <section>
        <h2>Ping target</h2>
        <form method="post" action="/diagnostics/ping">
          <label>Host or IP <input name="target" required></label>
          <button type="submit">Run ping</button>
        </form>
        <% if (pingOutput) { %>
          <pre><%= pingOutput %></pre>
        <% } %>
      </section>
      <section>
        <h2>Service health-check</h2>
        <form method="post" action="/diagnostics/health-check">
          <label>URL <input type="url" name="url" required></label>
          <button type="submit">Check service</button>
        </form>
        <% if (healthOutput) { %>
          <pre><%= healthOutput %></pre>
        <% } %>
      </section>
    </main>
  </body>
</html>
