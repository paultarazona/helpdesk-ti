<%- include('../partials/header', { title: 'Network Diagnostics' }) %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="container">
    <div class="flex-between mb-4">
      <div>
        <h1>Network Diagnostics</h1>
        <p class="text-muted">Perform ICMP ping tests and HTTP service health checks</p>
      </div>
      <a href="/dashboard" class="btn btn-outline">← Back to dashboard</a>
    </div>

    <div class="grid grid-2">
      <!-- Ping Target Card -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title flex-align-center gap-sm"><i data-lucide="radio"></i> Ping Target</h2>
        </div>
        <div class="card-body">
          <form method="post" action="/diagnostics/ping">
            <div class="form-group">
              <label class="form-label">Host or IP</label>
              <input class="form-control" name="target" required placeholder="e.g. 127.0.0.1 or localhost">
            </div>
            <button type="submit" class="btn btn-primary">Run ping</button>
          </form>

          <% if (pingOutput) { %>
            <div class="mt-4">
              <p class="form-label">Diagnostic Output:</p>
              <pre class="terminal-output"><%= pingOutput %></pre>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Service Health-Check Card -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title flex-align-center gap-sm"><i data-lucide="heart-pulse"></i> Service Health-Check</h2>
        </div>
        <div class="card-body">
          <form method="post" action="/diagnostics/health-check">
            <div class="form-group">
              <label class="form-label">URL</label>
              <input type="url" class="form-control" name="url" required placeholder="https://example.com">
            </div>
            <button type="submit" class="btn btn-primary">Check service</button>
          </form>

          <% if (healthOutput) { %>
            <div class="mt-4">
              <p class="form-label">Diagnostic Output:</p>
              <pre class="terminal-output"><%= healthOutput %></pre>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
