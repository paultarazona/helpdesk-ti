<%- include('../partials/header', { title: __('diagnostics.pageTitle') }) %>

<main class="main-content">
  <div class="container">
    <div class="grid grid-2">
      <!-- Ping Target Card -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title flex-align-center gap-sm"><i data-lucide="radio"></i> <%= __('diagnostics.pingTarget') %></h2>
        </div>
        <div class="card-body">
          <form method="post" action="/diagnostics/ping">
            <div class="form-group">
              <label class="form-label"><%= __('diagnostics.hostOrIp') %></label>
              <input class="form-control" name="target" required placeholder="<%= __('diagnostics.hostPlaceholder') %>">
            </div>
            <button type="submit" class="btn btn-primary"><%= __('diagnostics.runPing') %></button>
          </form>

          <% if (pingOutput) { %>
            <div class="mt-4">
              <p class="form-label"><%= __('diagnostics.diagnosticOutput') %></p>
              <pre class="terminal-output"><%= pingOutput %></pre>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Service Health-Check Card -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title flex-align-center gap-sm"><i data-lucide="heart-pulse"></i> <%= __('diagnostics.serviceHealthCheck') %></h2>
        </div>
        <div class="card-body">
          <form method="post" action="/diagnostics/health-check">
            <div class="form-group">
              <label class="form-label"><%= __('diagnostics.url') %></label>
              <input type="url" class="form-control" name="url" required placeholder="<%= __('diagnostics.urlPlaceholder') %>">
            </div>
            <button type="submit" class="btn btn-primary"><%= __('diagnostics.checkService') %></button>
          </form>

          <% if (healthOutput) { %>
            <div class="mt-4">
              <p class="form-label"><%= __('diagnostics.diagnosticOutput') %></p>
              <pre class="terminal-output"><%= healthOutput %></pre>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
