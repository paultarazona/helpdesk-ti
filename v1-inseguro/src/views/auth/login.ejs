<%- include('../partials/header', { title: 'Log in' }) %>

<main class="main-content">
  <div class="container container-narrow">
    <div class="card">
      <a href="/" class="card-close-btn" title="Close form" aria-label="Close">
        <i data-lucide="x" style="width: 18px; height: 18px;"></i>
      </a>
      <div class="card-header text-center" style="display: block;">
        <h1 class="card-title" style="justify-content: center;">IT Helpdesk Login</h1>
        <p class="text-muted" style="margin-top: 0.25rem;">Sign in to access support portal</p>
      </div>
      <div class="card-body">
        <% if (typeof error !== 'undefined') { %>
          <div class="alert alert-error">
            <span><%= error %></span>
          </div>
        <% } %>
        <form method="post" action="/login">
          <div class="form-group">
            <label class="form-label">Username</label>
            <input class="form-control" name="username" required autofocus>
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input class="form-control" name="password" type="password" required>
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg">Log in</button>
        </form>
      </div>
      <div class="card-footer text-center">
        <p class="text-muted" style="margin: 0;">
          Need an account? <a href="/register">Create an account</a>
        </p>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
