<%- include('../partials/header', { title: __('auth.registerTitle') }) %>

<main class="main-content">
  <div class="container container-narrow">
    <div class="card">
      <div class="card-header text-center" style="display: block;">
        <h1 class="card-title" style="justify-content: center;"><%= __('auth.registerTitle') %></h1>
        <p class="text-muted" style="margin-top: 0.25rem;"><%= __('auth.registerSubtitle') %></p>
      </div>
      <div class="card-body">
        <form method="post" action="/register">
          <div class="form-group">
            <label class="form-label"><%= __('auth.username') %></label>
            <input class="form-control" name="username" required autofocus>
          </div>
          <div class="form-group">
            <label class="form-label"><%= __('auth.email') %></label>
            <input class="form-control" name="email" type="email" required>
          </div>
          <div class="form-group">
            <label class="form-label"><%= __('auth.password') %></label>
            <input class="form-control" name="password" type="password" required>
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg"><%= __('auth.registerButton') %></button>
        </form>
      </div>
      <div class="card-footer">
        <a href="/login" class="btn btn-outline btn-block"><%= __('auth.loginButton') %></a>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
