<%- include('../partials/header', { title: 'Register' }) %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="container container-narrow">
    <div class="card">
      <a href="/" class="card-close-btn" title="Close form" aria-label="Close">
        <i data-lucide="x" style="width: 18px; height: 18px;"></i>
      </a>
      <div class="card-header text-center" style="display: block;">
        <h1 class="card-title" style="justify-content: center;">Register for IT Helpdesk</h1>
        <p class="text-muted" style="margin-top: 0.25rem;">Create a new user account</p>
      </div>
      <div class="card-body">
        <form method="post" action="/register">
          <div class="form-group">
            <label class="form-label">Username</label>
            <input class="form-control" name="username" required autofocus>
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-control" name="email" type="email" required>
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input class="form-control" name="password" type="password" required>
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg">Create account</button>
        </form>
      </div>
      <div class="card-footer text-center">
        <p class="text-muted" style="margin: 0;">
          Already have an account? <a href="/login">Back to login</a>
        </p>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
