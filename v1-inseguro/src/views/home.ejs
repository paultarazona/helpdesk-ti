<%- include('partials/header', { title: 'Home' }) %>
<%- include('partials/navbar') %>

<main class="main-content">
  <div class="container">
    <!-- Hero Section -->
    <div class="hero-card mb-4">
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: var(--color-primary-light); color: var(--color-primary); padding: 0.35rem 0.85rem; border-radius: 9999px; font-size: 0.85rem; font-weight: 600; margin-bottom: 1.25rem;">
        <i data-lucide="shield-check" style="width: 16px; height: 16px;"></i> Enterprise IT Operations Platform
      </div>
      <h1 class="hero-title">Streamline Your IT Support & Infrastructure</h1>
      <p class="hero-subtitle">
        A unified management solution for support ticket tracking, hardware asset inventory, and real-time network diagnostics.
      </p>
    </div>

    <!-- Feature Capabilities Grid -->
    <div class="grid grid-3 mb-4">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title flex-align-center gap-sm"><i data-lucide="ticket"></i> Ticket Workflow</h3>
        </div>
        <div class="card-body">
          <p class="text-muted">
            Submit, prioritize, and resolve technical support requests with comment threads, file attachments, and status tracking.
          </p>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3 class="card-title flex-align-center gap-sm"><i data-lucide="laptop"></i> Asset Inventory</h3>
        </div>
        <div class="card-body">
          <p class="text-muted">
            Maintain complete visibility over hardware workstations, servers, IP address allocations, and assigned users.
          </p>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3 class="card-title flex-align-center gap-sm"><i data-lucide="activity"></i> Network Diagnostics</h3>
        </div>
        <div class="card-body">
          <p class="text-muted">
            Troubleshoot connectivity with built-in ICMP ping tools and HTTP service health checks directly from the web console.
          </p>
        </div>
      </div>
    </div>

    <!-- Lab Disclaimer Banner -->
    <div class="card" style="background-color: var(--color-warning-light); border-color: #fde68a;">
      <div class="flex-between">
        <div>
          <h4 style="color: #92400e; margin-bottom: 0.25rem; display: flex; align-items: center; gap: 0.5rem;">
            <i data-lucide="alert-triangle" style="width: 18px; height: 18px;"></i> IT Helpdesk Security Lab
          </h4>
          <p style="color: #78350f; font-size: 0.875rem; margin: 0;">
            This application is designed for security training and must run only in a <strong>local isolated environment</strong>.
          </p>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
