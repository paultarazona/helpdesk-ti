<%- include('../partials/header', { title: heading }) %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="container container-narrow">
    <div class="card">
      <div class="card-header">
        <h1 class="card-title"><%= heading %></h1>
      </div>
      <div class="card-body">
        <form method="post" action="<%= action %>">
          <div class="form-group">
            <label class="form-label">Asset Name</label>
            <input class="form-control" name="name" value="<%= asset.name || '' %>" required autofocus placeholder="e.g. Workstation-Pro-01">
          </div>
          <div class="form-group">
            <label class="form-label">Asset Type</label>
            <input class="form-control" name="assetType" value="<%= asset.asset_type || '' %>" required placeholder="e.g. Laptop, Server, Router">
          </div>
          <div class="form-group">
            <label class="form-label">IP Address</label>
            <input class="form-control" name="ipAddress" value="<%= asset.ip_address || '' %>" placeholder="e.g. 192.168.1.50">
          </div>
          <div class="form-group">
            <label class="form-label">Assigned User</label>
            <select class="form-select" name="assignedToUserId">
              <option value="">Unassigned</option>
              <% users.forEach((user) => { %>
                <option value="<%= user.id %>" <%= String(asset.assigned_to_user_id) === String(user.id) ? 'selected' : '' %>><%= user.username %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save asset</button>
            <a href="/assets" class="btn btn-outline">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
