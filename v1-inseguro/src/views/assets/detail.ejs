<%- include('../partials/header', { title: asset.name }) %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="container">
    <div class="mb-3">
      <a href="/assets" class="btn btn-sm btn-outline">← Back to assets</a>
    </div>

    <div class="grid grid-2">
      <!-- Asset Specification Card -->
      <div class="card">
        <div class="card-header flex-between">
          <div>
            <h1 class="card-title"><%= asset.name %></h1>
            <span class="badge badge-low mt-1"><%= asset.asset_type %></span>
          </div>
          <div class="flex gap-sm">
            <a href="/assets/<%= asset.id %>/edit" class="btn btn-secondary">Edit asset</a>
            <form method="post" action="/assets/<%= asset.id %>/delete" style="display: inline-block; margin: 0;">
              <button type="submit" class="btn btn-danger">Delete</button>
            </form>
          </div>
        </div>
        <div class="card-body">
          <div class="grid grid-2 gap-md">
            <div>
              <p class="text-muted mb-1" style="font-size: 0.85rem;">IP Address</p>
              <p><code><%= asset.ip_address || 'Not configured' %></code></p>
            </div>
            <div>
              <p class="text-muted mb-1" style="font-size: 0.85rem;">Assigned User</p>
              <p><strong><%= asset.assigned_username || 'Unassigned' %></strong></p>
            </div>
            <div>
              <p class="text-muted mb-1" style="font-size: 0.85rem;">Created By</p>
              <p><%= asset.created_by_username || 'Unknown' %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Related Tickets Card -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title flex-align-center gap-sm"><i data-lucide="ticket"></i> Related Tickets</h2>
        </div>
        <div class="card-body">
          <% if (tickets.length === 0) { %>
            <p class="text-muted">No tickets linked to this asset.</p>
          <% } else { %>
            <ul style="list-style: none; padding: 0;">
              <% tickets.forEach((ticket) => { %>
                <li style="padding: 0.65rem 0; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center;">
                  <a href="/tickets/<%= ticket.id %>" style="font-weight: 600;"><%= ticket.subject %></a>
                  <div class="flex gap-sm">
                    <span class="badge badge-<%= ticket.status %>"><%= ticket.status %></span>
                    <span class="badge badge-<%= ticket.priority %>"><%= ticket.priority %></span>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
