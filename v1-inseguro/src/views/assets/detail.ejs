<%- include('../partials/header', { title: asset.name }) %>

<main class="main-content">
  <div class="container">
    <div class="mb-3">
      <a href="/assets" class="btn btn-sm btn-outline">← <%= __('assets.backToAssets') %></a>
    </div>

    <div class="grid grid-2">
      <!-- Asset Specification Card -->
      <div class="card">
        <div class="card-header flex-between">
          <div>
            <h1 class="card-title"><%= asset.name %></h1>
            <span class="badge badge-low mt-1"><%= asset.asset_type %></span>
          </div>
          <div class="flex gap-sm">
            <a href="/assets/<%= asset.id %>/edit" class="btn btn-secondary"><%= __('assets.editAsset') %></a>
            <form method="post" action="/assets/<%= asset.id %>/delete" style="display: inline-block; margin: 0;">
              <button type="submit" class="btn btn-danger"><%= __('assets.delete') %></button>
            </form>
          </div>
        </div>
        <div class="card-body">
          <div class="grid grid-2 gap-md">
            <div>
              <p class="text-muted mb-1" style="font-size: 0.85rem;"><%= __('assets.ipAddress') %></p>
              <p><code><%= asset.ip_address || __('assets.notConfigured') %></code></p>
            </div>
            <div>
              <p class="text-muted mb-1" style="font-size: 0.85rem;"><%= __('assets.assignedUser') %></p>
              <p><strong><%= asset.assigned_username || __('assets.unassigned') %></strong></p>
            </div>
            <div>
              <p class="text-muted mb-1" style="font-size: 0.85rem;"><%= __('assets.createdBy') %></p>
              <p><%= asset.created_by_username || __('assets.unknown') %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Related Tickets Card -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title flex-align-center gap-sm"><i data-lucide="ticket"></i> <%= __('assets.relatedTickets') %></h2>
        </div>
        <div class="card-body">
          <% if (tickets.length === 0) { %>
            <p class="text-muted"><%= __('assets.noLinkedTickets') %></p>
          <% } else { %>
            <ul style="list-style: none; padding: 0;">
              <% tickets.forEach((ticket) => { %>
                <li style="padding: 0.65rem 0; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center;">
                  <a href="/tickets/<%= ticket.id %>" style="font-weight: 600;"><%= ticket.subject %></a>
                  <div class="flex gap-sm">
                    <span class="badge badge-<%= ticket.status %>"><%= ticket.status %></span>
                    <span class="badge badge-<%= ticket.priority %>"><%= ticket.priority %></span>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
