<%- include('../partials/header', { title: __('assets.pageTitle') }) %>

<main class="main-content">
  <div class="container">
    <div class="flex-between mb-4">
      <div>
        <h1><%= __('assets.pageTitle') %></h1>
        <p class="text-muted"><%= __('assets.pageSubtitle') %></p>
      </div>
      <div class="flex gap-md">
        <a href="/dashboard" class="btn btn-outline"><%= __('sidebar.dashboard') %></a>
        <a href="/assets/new" class="btn btn-primary"><%= __('assets.createAsset') %></a>
      </div>
    </div>

    <div class="card mb-4">
      <form method="get" action="/assets" class="form-inline">
        <div class="form-group" style="flex: 1;">
          <label class="form-label"><%= __('assets.searchByNameOrIp') %></label>
          <input class="form-control" name="search" value="<%= search %>" placeholder="<%= __('assets.searchPlaceholder') %>">
        </div>
        <button type="submit" class="btn btn-secondary"><%= __('assets.search') %></button>
      </form>
    </div>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><%= __('assets.colName') %></th>
            <th><%= __('assets.colType') %></th>
            <th><%= __('assets.colIp') %></th>
            <th><%= __('assets.colAssignedUser') %></th>
            <th><%= __('assets.colAction') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (assets.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center text-muted" style="padding: 2rem;"><%= __('assets.noAssets') %></td>
            </tr>
          <% } %>
          <% assets.forEach((asset) => { %>
            <tr>
              <td>
                <a href="/assets/<%= asset.id %>" style="font-weight: 600;"><%= asset.name %></a>
              </td>
              <td>
                <span class="badge badge-low"><%= asset.asset_type %></span>
              </td>
              <td>
                <code><%= asset.ip_address || __('assets.noIp') %></code>
              </td>
              <td><%= asset.assigned_username || __('assets.unassigned') %></td>
              <td>
                <a href="/assets/<%= asset.id %>" class="btn btn-sm btn-outline"><%= __('assets.details') %></a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
