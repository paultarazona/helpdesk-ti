<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= typeof title !== 'undefined' ? title + ' | IT Helpdesk' : 'IT Helpdesk Security Lab' %></title>
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
    <!-- Vanilla CSS Design System -->
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body class="app-viewport">
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="app-shell">
      <%- include('sidebar') %>
      <div class="app-content">
    <% } else { %>
    <header class="top-bar">
      <div class="container top-bar-inner">
        <a href="/login" class="brand">
          <span class="brand-icon"><i data-lucide="headset" style="width: 18px; height: 18px;"></i></span>
          <span>IT Helpdesk</span>
        </a>
        <div class="top-bar-actions">
          <a href="/login" class="btn btn-sm btn-outline">Log in</a>
          <a href="/register" class="btn btn-sm btn-primary">Register</a>
        </div>
      </div>
    </header>
    <% } %>
