<!doctype html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= typeof title !== 'undefined' ? title + ' | ' + __('common.appName') : __('common.appName') %></title>
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
    <!-- Vanilla CSS Design System -->
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body class="app-viewport">
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="app-shell">
      <%- include('sidebar') %>
      <div class="app-content">
        <%- include('topbar') %>
    <% } else { %>
    <header class="top-bar">
      <div class="container top-bar-inner">
        <a href="/login" class="brand">
          <span class="brand-icon"><i data-lucide="headset" style="width: 18px; height: 18px;"></i></span>
          <span><%= __('common.appName') %></span>
        </a>
        <div class="top-bar-actions">
          <%- include('lang-switcher') %>
        </div>
      </div>
    </header>
    <% } %>
