<footer class="app-footer">
  <div class="container footer-content">
    <div class="lab-disclaimer">
      <span><i data-lucide="alert-triangle" style="width: 16px; height: 16px; margin-right: 4px;"></i> <strong>IT Helpdesk Security Lab</strong> — Deliberately vulnerable application for educational use only.</span>
    </div>
    <p class="text-muted" style="font-size: 0.8rem; margin: 0;">
      Enterprise Light Design System &copy; 2026 IT Helpdesk Security Lab
    </p>
  </div>
</footer>
<script src="https://unpkg.com/lucide@latest"></script>
<script>
  if (typeof lucide !== 'undefined') {
    lucide.createIcons();
  }

  // Reveal footer when user scrolls down
  document.addEventListener('DOMContentLoaded', function() {
    const footer = document.querySelector('.app-footer');
    if (!footer) return;

    function checkScroll() {
      const scrollY = window.scrollY || window.pageYOffset;
      const windowHeight = window.innerHeight;
      const docHeight = document.documentElement.scrollHeight;

      // Show footer if user scrolled down (>40px) or reached document bottom
      if (scrollY > 40 || (scrollY + windowHeight >= docHeight - 20)) {
        footer.classList.add('footer-visible');
      } else {
        footer.classList.remove('footer-visible');
      }
    }

    window.addEventListener('scroll', checkScroll, { passive: true });
    checkScroll();
  });
</script>
</body>
</html>
