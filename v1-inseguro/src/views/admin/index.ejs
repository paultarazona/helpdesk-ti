<%- include('../partials/header', { title: 'Administration' }) %>

<main class="main-content">
  <div class="container">
    <div class="flex-between mb-4">
      <div>
        <h1>Administration</h1>
        <p class="text-muted">User accounts & privileges governance</p>
      </div>
      <a href="/dashboard" class="btn btn-outline">← Back to dashboard</a>
    </div>

    <div class="card">
      <div class="card-header">
        <h2 class="card-title flex-align-center gap-sm"><i data-lucide="users"></i> User Accounts</h2>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((user) => { %>
                <tr>
                  <td><code>#<%= user.id %></code></td>
                  <td><strong><%= user.username %></strong></td>
                  <td><%= user.email %></td>
                  <td>
                    <span class="badge badge-<%= user.role === 'admin' ? 'urgent' : 'medium' %>">
                      <%= user.role %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
