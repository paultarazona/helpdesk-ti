<%- include('../partials/header', { title: __('admin.pageTitle') }) %>

<main class="main-content">
  <div class="container">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title flex-align-center gap-sm"><i data-lucide="users"></i> <%= __('admin.userAccounts') %></h2>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th><%= __('admin.colId') %></th>
                <th><%= __('admin.colUsername') %></th>
                <th><%= __('admin.colEmail') %></th>
                <th><%= __('admin.colRole') %></th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((user) => { %>
                <tr>
                  <td><code>#<%= user.id %></code></td>
                  <td><strong><%= user.username %></strong></td>
                  <td><%= user.email %></td>
                  <td>
                    <span class="badge badge-<%= user.role === 'admin' ? 'urgent' : 'medium' %>">
                      <%= user.role %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
