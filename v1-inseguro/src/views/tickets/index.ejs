<%- include('../partials/header', { title: __('tickets.pageTitle') }) %>

<main class="main-content">
  <div class="container">
    <div class="flex-between mb-4">
      <div>
        <h1><%= __('tickets.pageTitle') %></h1>
        <p class="text-muted"><%= __('tickets.pageSubtitle') %></p>
      </div>
      <div class="flex gap-md">
        <a href="/dashboard" class="btn btn-outline"><%= __('sidebar.dashboard') %></a>
        <a href="/tickets/new" class="btn btn-primary"><%= __('tickets.createTicket') %></a>
      </div>
    </div>

    <div class="card mb-4">
      <form method="get" action="/tickets" class="form-inline">
        <div class="form-group">
          <label class="form-label"><%= __('tickets.searchLabel') %></label>
          <input class="form-control" name="search" value="<%= search %>" placeholder="<%= __('tickets.searchPlaceholder') %>">
        </div>
        <div class="form-group">
          <label class="form-label"><%= __('tickets.statusLabel') %></label>
          <input class="form-control" name="status" value="<%= status %>" placeholder="<%= __('tickets.statusPlaceholder') %>">
        </div>
        <div class="form-group">
          <label class="form-label"><%= __('tickets.priorityLabel') %></label>
          <input class="form-control" name="priority" value="<%= priority %>" placeholder="<%= __('tickets.priorityPlaceholder') %>">
        </div>
        <button type="submit" class="btn btn-secondary"><%= __('tickets.filter') %></button>
      </form>
    </div>

    <% if (search) { %>
      <!-- [VULN-003][A03:XSS-Reflected][CWE-79] The search text is intentionally unescaped in v1. -->
      <div class="alert alert-info mb-4">
        <span><%= __('tickets.searchResultsFor') %> <%- search %></span>
      </div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><%= __('tickets.colSubject') %></th>
            <th><%= __('tickets.colStatus') %></th>
            <th><%= __('tickets.colPriority') %></th>
            <th><%= __('tickets.colRequester') %></th>
            <th><%= __('tickets.colAction') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (tickets.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center text-muted" style="padding: 2rem;"><%= __('tickets.noTickets') %></td>
            </tr>
          <% } %>
          <% tickets.forEach((ticket) => { %>
            <tr>
              <td>
                <a href="/tickets/<%= ticket.id %>" style="font-weight: 600;"><%= ticket.subject %></a>
              </td>
              <td>
                <span class="badge badge-<%= ticket.status %>"><%= ticket.status %></span>
              </td>
              <td>
                <span class="badge badge-<%= ticket.priority %>"><%= ticket.priority %></span>
              </td>
              <td><%= ticket.requester_username %></td>
              <td>
                <a href="/tickets/<%= ticket.id %>" class="btn btn-sm btn-outline"><%= __('tickets.view') %></a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
