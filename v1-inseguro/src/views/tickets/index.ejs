<%- include('../partials/header', { title: 'Tickets' }) %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="container">
    <div class="flex-between mb-4">
      <div>
        <h1>Tickets</h1>
        <p class="text-muted">Browse and manage IT support tickets</p>
      </div>
      <div class="flex gap-md">
        <a href="/dashboard" class="btn btn-outline">Dashboard</a>
        <a href="/tickets/new" class="btn btn-primary">+ Create ticket</a>
      </div>
    </div>

    <div class="card mb-4">
      <form method="get" action="/tickets" class="form-inline">
        <div class="form-group">
          <label class="form-label">Search</label>
          <input class="form-control" name="search" value="<%= search %>" placeholder="Subject or keyword...">
        </div>
        <div class="form-group">
          <label class="form-label">Status</label>
          <input class="form-control" name="status" value="<%= status %>" placeholder="open, closed...">
        </div>
        <div class="form-group">
          <label class="form-label">Priority</label>
          <input class="form-control" name="priority" value="<%= priority %>" placeholder="low, high...">
        </div>
        <button type="submit" class="btn btn-secondary">Filter</button>
      </form>
    </div>

    <% if (search) { %>
      <!-- [VULN-003][A03:XSS-Reflected][CWE-79] The search text is intentionally unescaped in v1. -->
      <div class="alert alert-info mb-4">
        <span>Search results for: <%- search %></span>
      </div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>Subject</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Requester</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (tickets.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center text-muted" style="padding: 2rem;">No tickets found.</td>
            </tr>
          <% } %>
          <% tickets.forEach((ticket) => { %>
            <tr>
              <td>
                <a href="/tickets/<%= ticket.id %>" style="font-weight: 600;"><%= ticket.subject %></a>
              </td>
              <td>
                <span class="badge badge-<%= ticket.status %>"><%= ticket.status %></span>
              </td>
              <td>
                <span class="badge badge-<%= ticket.priority %>"><%= ticket.priority %></span>
              </td>
              <td><%= ticket.requester_username %></td>
              <td>
                <a href="/tickets/<%= ticket.id %>" class="btn btn-sm btn-outline">View</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
