<%- include('../partials/header', { title: __('tickets.pageTitle') }) %>

<main class="main-content">
  <div class="container">
    <div class="flex gap-md mb-4" style="justify-content: flex-end;">
      <a href="/tickets/new" class="btn btn-primary"><%= __('tickets.createTicket') %></a>
    </div>

    <div class="card mb-4">
      <form method="get" action="/tickets" class="form-inline">
        <div class="form-group">
          <label class="form-label"><%= __('tickets.searchLabel') %></label>
          <input class="form-control" name="search" value="<%= search %>" placeholder="<%= __('tickets.searchPlaceholder') %>">
        </div>
        <div class="form-group">
          <label class="form-label"><%= __('tickets.statusLabel') %></label>
          <select class="form-control" name="status">
            <option value="" <%= status === '' ? 'selected' : '' %>><%= __('tickets.statusOptions.all') %></option>
            <option value="open" <%= status === 'open' ? 'selected' : '' %>><%= __('tickets.statusOptions.open') %></option>
            <option value="in_progress" <%= status === 'in_progress' ? 'selected' : '' %>><%= __('tickets.statusOptions.in_progress') %></option>
            <option value="closed" <%= status === 'closed' ? 'selected' : '' %>><%= __('tickets.statusOptions.closed') %></option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label"><%= __('tickets.priorityLabel') %></label>
          <select class="form-control" name="priority">
            <option value="" <%= priority === '' ? 'selected' : '' %>><%= __('tickets.priorityOptions.all') %></option>
            <option value="low" <%= priority === 'low' ? 'selected' : '' %>><%= __('tickets.priorityOptions.low') %></option>
            <option value="medium" <%= priority === 'medium' ? 'selected' : '' %>><%= __('tickets.priorityOptions.medium') %></option>
            <option value="high" <%= priority === 'high' ? 'selected' : '' %>><%= __('tickets.priorityOptions.high') %></option>
            <option value="critical" <%= priority === 'critical' ? 'selected' : '' %>><%= __('tickets.priorityOptions.critical') %></option>
          </select>
        </div>
        <button type="submit" class="btn btn-secondary"><%= __('tickets.filter') %></button>
        <a href="/tickets" class="btn btn-ghost"><%= __('tickets.clearFilters') %></a>
      </form>
    </div>

    <% if (search) { %>
      <!-- [VULN-003][A03:XSS-Reflected][CWE-79] The search text is intentionally unescaped in v1. -->
      <div class="alert alert-info mb-4">
        <span><%= __('tickets.searchResultsFor') %> <%- search %></span>
      </div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th><%= __('tickets.colSubject') %></th>
            <th><%= __('tickets.colStatus') %></th>
            <th><%= __('tickets.colPriority') %></th>
            <th><%= __('tickets.colRequester') %></th>
            <th><%= __('tickets.colAction') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (tickets.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center text-muted" style="padding: 2rem;"><%= __('tickets.noTickets') %></td>
            </tr>
          <% } %>
          <% tickets.forEach((ticket) => { %>
            <tr>
              <td>
                <a href="/tickets/<%= ticket.id %>" style="font-weight: 600;"><%= ticket.subject %></a>
              </td>
              <td>
                <span class="badge badge-<%= ticket.status %>"><%= __('tickets.statusOptions.' + ticket.status) %></span>
              </td>
              <td>
                <span class="badge badge-<%= ticket.priority %>"><%= __('tickets.priorityOptions.' + ticket.priority) %></span>
              </td>
              <td><%= ticket.requester_username %></td>
              <td>
                <a href="/tickets/<%= ticket.id %>" class="btn btn-sm btn-outline"><%= __('tickets.view') %></a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
