<%- include('../partials/header', { title: heading }) %>

<main class="main-content">
  <div class="container container-narrow">
    <div class="card">
      <div class="card-header">
        <h1 class="card-title"><%= heading %></h1>
      </div>
      <div class="card-body">
        <form method="post" action="<%= action %>">
          <!-- [VULN-005][A01:CSRF][CWE-352] Deliberately no CSRF token in v1. -->
          <div class="form-group">
            <label class="form-label"><%= __('tickets.form.subject') %></label>
            <input class="form-control" name="subject" value="<%= ticket.subject || '' %>" required autofocus>
          </div>
          <div class="form-group">
            <label class="form-label"><%= __('tickets.form.description') %></label>
            <textarea class="form-control" name="description" rows="5" required><%= ticket.description || '' %></textarea>
          </div>
          <div class="grid grid-2 mb-3">
            <div class="form-group">
              <label class="form-label"><%= __('tickets.form.status') %></label>
              <select class="form-control" name="status">
                <option value="open" <%= (ticket.status || 'open') === 'open' ? 'selected' : '' %>><%= __('tickets.statusOptions.open') %></option>
                <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>><%= __('tickets.statusOptions.in_progress') %></option>
                <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>><%= __('tickets.statusOptions.closed') %></option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label"><%= __('tickets.form.priority') %></label>
              <select class="form-control" name="priority">
                <option value="low" <%= (ticket.priority || 'medium') === 'low' ? 'selected' : '' %>><%= __('tickets.priorityOptions.low') %></option>
                <option value="medium" <%= (ticket.priority || 'medium') === 'medium' ? 'selected' : '' %>><%= __('tickets.priorityOptions.medium') %></option>
                <option value="high" <%= ticket.priority === 'high' ? 'selected' : '' %>><%= __('tickets.priorityOptions.high') %></option>
                <option value="critical" <%= ticket.priority === 'critical' ? 'selected' : '' %>><%= __('tickets.priorityOptions.critical') %></option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label"><%= __('tickets.form.asset') %></label>
            <select class="form-select" name="assetId">
              <option value=""><%= __('tickets.form.noAsset') %></option>
              <% assets.forEach((asset) => { %>
                <option value="<%= asset.id %>" <%= String(ticket.asset_id) === String(asset.id) ? 'selected' : '' %>><%= asset.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= __('tickets.form.save') %></button>
            <a href="/tickets" class="btn btn-outline"><%= __('common.cancel') %></a>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
