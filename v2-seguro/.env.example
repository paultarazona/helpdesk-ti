# Copy this file to .env and fill in real local values.
# .env is git-ignored (see repo root .gitignore) - never commit real secrets.

NODE_ENV=development
PORT=4000

# Discrete Postgres connection params (used by knexfile.js / src/db/connection.js).
# Distinct DB name, user and port from v1-inseguro so both stacks can run in
# parallel without colliding.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=helpdesk_v2
DB_USER=helpdesk_v2
DB_PASSWORD=replace-with-a-local-lab-password

# JWT signing secret. There is NO hardcoded default in src/config/env.js -
# the app refuses to start without this set (contrast with v1's hardcoded
# fallback secret).
JWT_SECRET=replace-with-a-long-random-local-lab-secret
JWT_EXPIRES_IN=15m

# Restrict CORS to this origin (no wildcard in production).
CORS_ORIGIN=http://localhost:4000
